-- ══════════════════════════════
--  BUTTON LOGIC
-- ══════════════════════════════
local function setVisible(v)
    visible          = v
    frame.Visible    = v
    floatBtn.Visible = not v
end

local function setFrozen(v)
    frozen = v
    if frozen then
        freezeBtn.Text             = "❄   FREEZE  —  ON"
        freezeBtn.BackgroundColor3 = C.accent
        freezeBtn.TextColor3       = C.black
        sDot.BackgroundColor3      = Color3.fromRGB(80, 160, 255)
        sLbl.Text                  = "Frozen  ·  frame held"
    else
        freezeBtn.Text             = "❄   FREEZE  —  OFF"
        freezeBtn.BackgroundColor3 = C.btnBg
        freezeBtn.TextColor3       = C.text
        sDot.BackgroundColor3      = C.green
        sLbl.Text                  = "Running  ·  tracks: 0"
    end
end

-- NEW v2.5
local function setReversed(v)
    reversed = v
    if reversed then
        -- Jump every track to its END so it immediately plays backwards
        local hum = GetHum()
        if hum then
            for _, t in ipairs(hum:GetPlayingAnimationTracks()) do
                if t.Length > 0 then
                    t:AdjustSpeed(0)
                    t.TimePosition = t.Length
                end
            end
        end
        reverseBtn.Text             = "⟲   REVERSE  —  ON"
        reverseBtn.BackgroundColor3 = C.purple
        reverseBtn.TextColor3       = C.white
        sDot.BackgroundColor3       = C.purple
        sLbl.Text                   = "⟲ Reversed  ·  tracks: 0"
    else
        reverseBtn.Text             = "⟲   REVERSE  —  OFF"
        reverseBtn.BackgroundColor3 = C.btnBg
        reverseBtn.TextColor3       = C.text
        sDot.BackgroundColor3       = C.green
        sLbl.Text                   = "Running  ·  tracks: 0"
    end
end

freezeBtn.MouseButton1Click:Connect(function()  setFrozen(not frozen)     end)
reverseBtn.MouseButton1Click:Connect(function() setReversed(not reversed) end)  -- NEW
hideBtn.MouseButton1Click:Connect(function()    setVisible(false)          end)
