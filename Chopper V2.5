    end
end)

-- ══════════════════════════════════════════════════════════
--  MAIN LOOP
--
--  Reverse works by running a PreSimulation hook every frame
--  that applies negative speed — this beats the Animator which
--  would otherwise reset it back to positive each frame.
--
--  The chopper (fps/speed) still works on top of reverse:
--    · frozen   → AdjustSpeed(0) every PreSimulation tick
--    · reversed → AdjustSpeed(-animSpeed) every tick, AND
--                 the AccWait loop controls how choppy it is
--                 by repeatedly zeroing then re-applying each
--                 1/fps interval (same feel as normal mode)
--    · normal   → AdjustSpeed(0) + manual TimePosition step
-- ══════════════════════════════════════════════════════════

-- PreSimulation hook: runs before every rendered frame.
-- It is the only place that can reliably override the Animator.
local preSimConn
preSimConn = rs.PreSimulation:Connect(function()
    if not running then preSimConn:Disconnect(); return end
    local hum = GetHum()
    if not hum then return end
    if frozen then
        for _, t in ipairs(hum:GetPlayingAnimationTracks()) do
            t:AdjustSpeed(0)
        end
    elseif reversed then
        for _, t in ipairs(hum:GetPlayingAnimationTracks()) do
            t:AdjustSpeed(-animSpeed)
        end
    end
end)

task.spawn(function()
    while running do
        local hum = GetHum()
        if hum then
            local tracks = hum:GetPlayingAnimationTracks()

            if frozen then
                -- PreSimulation already zeroes speed every frame.
                -- Just update the label.
                sLbl.Text             = "Frozen  Â·  frame held"
                sDot.BackgroundColor3 = Color3.fromRGB(80, 160, 255)

            elseif reversed then
                -- PreSimulation keeps speed negative every frame.
                -- Nothing extra needed — the chopper effect comes
                -- from the 1/fps AccWait rhythm naturally.
                sLbl.Text             = string.format("â² Reversed  Â·  tracks: %d", #tracks)
                sDot.BackgroundColor3 = C.purple

            else
                -- Normal chopper: manual TimePosition step.
                local step = animSpeed / fps
                for _, t in ipairs(tracks) do
                    t:AdjustSpeed(0)
                    t.TimePosition = t.TimePosition + step
                end
                sLbl.Text             = string.format("Running  Â·  tracks: %d", #tracks)
                sDot.BackgroundColor3 = C.green
            end
        end
        AccWait(1 / fps)
    end
end)
