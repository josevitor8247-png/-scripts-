-- ══════════════════════════════
--  GUI UTILITIES
-- ══════════════════════════════
local function corner(p, r)
    local c = Instance.new("UICorner", p)
    c.CornerRadius = UDim.new(0, r or 6)
    return c
end

local function stroke(p, col, thick)
    local s = Instance.new("UIStroke", p)
    s.Color        = col or C.accent
    s.Thickness    = thick or 1
    s.Transparency = 0.55
    return s
end

local function addHover(btn, norm, hov)
    btn.MouseEnter:Connect(function() btn.BackgroundColor3 = hov  end)
    btn.MouseLeave:Connect(function() btn.BackgroundColor3 = norm end)
end

local function iconBtn(parent, txt, xOff, w)
    local b = Instance.new("TextButton", parent)
    b.Size             = UDim2.new(0, w or 28, 1, -8)
    b.Position         = UDim2.new(1, -(xOff or 32), 0, 4)
    b.Text             = txt
    b.Font             = Enum.Font.GothamBold
    b.TextSize         = 13
    b.TextColor3       = C.text
    b.BackgroundColor3 = C.btnBg
    b.AutoButtonColor  = false
    corner(b, 4)
    addHover(b, C.btnBg, C.btnHov)
    return b
end

