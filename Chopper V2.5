    pb.TextColor3       = C.text
    pb.BackgroundColor3 = C.btnBg
    pb.AutoButtonColor  = false
    corner(pb, 5)
    local pval = p[2]
    table.insert(presetBtns, {btn=pb, val=pval})
    pb.MouseButton1Click:Connect(function()
        animSpeed = pval
        speedValLbl.Text = string.format("%.2f", pval)
