local PRESETS    = {{"0×",0},{"¼×",0.25},{"½×",0.5},{"1×",1},{"2×",2}}
local presetBtns = {}

local function highlightPreset(val)
    for _, info in ipairs(presetBtns) do
        local on = (math.abs(info.val - val) < 0.001)
        info.btn.BackgroundColor3 = on and C.accent or C.btnBg
        info.btn.TextColor3       = on and C.black  or C.text
    end
end

for _, p in ipairs(PRESETS) do
    local pb = Instance.new("TextButton", c4)
    pb.Size             = UDim2.new(0, 36, 0, 28)
    pb.Text             = p[1]
    pb.Font             = Enum.Font.GothamBold
